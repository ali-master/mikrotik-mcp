# This Raycast extension is published via npm (`ray build` / `npm run publish`),
# independent of the root project's Bun toolchain. Keeping a local .npmrc here
# means npm reads THIS as the project config and never the root's Bun/pnpm one
# (whose `strict-peer-dependencies` / `modules-cache-max-age` keys npm rejects).
legacy-peer-deps=true

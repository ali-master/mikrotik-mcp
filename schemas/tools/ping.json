{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ping",
  "type": "object",
  "properties": {
    "address": {
      "type": "string",
      "description": "Target host or IP to ping"
    },
    "count": {
      "default": 4,
      "description": "Number of echo requests (1-100)",
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "interface": {
      "description": "Outgoing interface",
      "type": "string"
    },
    "src_address": {
      "description": "Source address to ping from",
      "type": "string"
    },
    "size": {
      "description": "Packet size in bytes",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    }
  },
  "required": ["address", "count"],
  "additionalProperties": false
}

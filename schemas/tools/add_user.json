{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_user",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "group": {
      "default": "read",
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "name",
    "password",
    "group",
    "disabled"
  ],
  "additionalProperties": false
}

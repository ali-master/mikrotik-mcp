{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "update_queue_tree",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "new_name": {
      "type": "string"
    },
    "parent": {
      "type": "string"
    },
    "queue": {
      "type": "string"
    },
    "packet_mark": {
      "type": "string"
    },
    "max_limit": {
      "description": "Bandwidth e.g. \"10M\", \"512k\"",
      "type": "string"
    },
    "limit_at": {
      "description": "Bandwidth e.g. \"10M\", \"512k\"",
      "type": "string"
    },
    "burst_limit": {
      "description": "Bandwidth e.g. \"10M\", \"512k\"",
      "type": "string"
    },
    "burst_threshold": {
      "description": "Bandwidth e.g. \"10M\", \"512k\"",
      "type": "string"
    },
    "burst_time": {
      "description": "Duration e.g. \"8s\"",
      "type": "string"
    },
    "bucket_size": {
      "type": "string"
    },
    "priority": {
      "description": "1 (highest) – 8 (lowest)",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "type": "boolean"
    }
  },
  "required": ["name"],
  "additionalProperties": false
}

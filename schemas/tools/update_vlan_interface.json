{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "update_vlan_interface",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Current name of the VLAN interface to update"
    },
    "new_name": {
      "type": "string"
    },
    "vlan_id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4094
    },
    "interface": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "type": "boolean"
    },
    "mtu": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "use_service_tag": {
      "type": "boolean"
    },
    "arp": {
      "type": "string",
      "enum": ["enabled", "disabled", "proxy-arp", "reply-only"]
    },
    "arp_timeout": {
      "type": "string"
    }
  },
  "required": ["name"],
  "additionalProperties": false
}

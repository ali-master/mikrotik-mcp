{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_user_manager_limitation",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Limitation name"
    },
    "rate_limit_rx": {
      "description": "Download rate limit, e.g. '10M'",
      "type": "string"
    },
    "rate_limit_tx": {
      "description": "Upload rate limit, e.g. '10M'",
      "type": "string"
    },
    "transfer_limit": {
      "description": "Total transfer cap, e.g. '10G'",
      "type": "string"
    },
    "uptime_limit": {
      "description": "Uptime cap, e.g. '1d'",
      "type": "string"
    },
    "comment": {
      "type": "string"
    }
  },
  "required": ["name"],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_ipv6_default_route",
  "type": "object",
  "properties": {
    "gateway": {
      "type": "string",
      "description": "Next-hop IPv6 address or interface"
    },
    "distance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 255
    },
    "check_gateway": {
      "type": "string"
    },
    "routing_table": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": ["gateway", "disabled"],
  "additionalProperties": false
}

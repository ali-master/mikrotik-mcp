{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_scheduler",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name for the scheduler entry"
    },
    "on_event": {
      "type": "string",
      "description": "Script source to run on event (may contain spaces/semicolons)"
    },
    "interval": {
      "description": "Run interval, e.g. '00:05:00' (0 = run once)",
      "type": "string"
    },
    "start_time": {
      "description": "Start time, e.g. '12:00:00' or 'startup'",
      "type": "string"
    },
    "start_date": {
      "description": "Start date, e.g. 'jan/01/2026'",
      "type": "string"
    },
    "policy": {
      "description": "Permission policy list, e.g. 'read,write,test,policy'",
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "name",
    "on_event",
    "disabled"
  ],
  "additionalProperties": false
}

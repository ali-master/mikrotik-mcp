{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "speed_test",
  "type": "object",
  "properties": {
    "address": {
      "type": "string",
      "description": "Target RouterOS device address"
    },
    "duration": {
      "default": 10,
      "description": "Test duration in seconds (bounds the run)",
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "direction": {
      "default": "both",
      "type": "string",
      "enum": [
        "receive",
        "transmit",
        "both"
      ]
    },
    "tcp_connection_count": {
      "description": "Parallel TCP connections to use",
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "user": {
      "description": "Username for the target device",
      "type": "string"
    },
    "password": {
      "description": "Password for the target device",
      "type": "string"
    }
  },
  "required": [
    "address",
    "duration",
    "direction"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "update_ip_pool",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "new_name": {
      "type": "string"
    },
    "ranges": {
      "description": "Hyphen-separated range(s) e.g. \"192.168.1.1-192.168.1.100\". Multiple ranges comma-separated: \"10.0.0.1-10.0.0.50,10.0.0.100-10.0.0.120\"",
      "type": "string"
    },
    "next_pool": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    }
  },
  "required": ["name"],
  "additionalProperties": false
}

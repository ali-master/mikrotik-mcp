{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_dns_static",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "type": {
      "description": "Record type, e.g. \"A\", \"AAAA\", \"CNAME\", \"NS\", \"FWD\", \"MX\", \"SRV\", \"TXT\"",
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "cname": {
      "type": "string"
    },
    "ns": {
      "description": "Name server FQDN for an NS-type record",
      "type": "string"
    },
    "forward_to": {
      "description": "DNS server to forward to for a FWD-type record",
      "type": "string"
    },
    "match_subdomain": {
      "description": "Also match all subdomains of name/regexp",
      "type": "boolean"
    },
    "address_list": {
      "description": "Add resolved addresses to this firewall address-list",
      "type": "string"
    },
    "mx_preference": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "mx_exchange": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "srv_priority": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "srv_weight": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "srv_port": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "srv_target": {
      "type": "string"
    },
    "ttl": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    },
    "regexp": {
      "type": "string"
    }
  },
  "required": ["name", "disabled"],
  "additionalProperties": false
}

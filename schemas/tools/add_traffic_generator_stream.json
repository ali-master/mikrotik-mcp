{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_traffic_generator_stream",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "port": {
      "type": "string",
      "description": "Traffic-generator port name"
    },
    "tx_template": {
      "description": "Packet-template name to transmit",
      "type": "string"
    },
    "packet_size": {
      "description": "Packet size or range",
      "type": "string"
    },
    "tx_rate": {
      "description": "Transmit rate in bits/second",
      "type": "string"
    },
    "num": {
      "description": "Stream number (0-15)",
      "type": "integer",
      "minimum": 0,
      "maximum": 15
    },
    "pps": {
      "description": "Target throughput in packets per second",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "mbps": {
      "description": "Target throughput in megabits per second",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "name",
    "port",
    "disabled"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_rpki_session",
  "type": "object",
  "properties": {
    "group": {
      "type": "string",
      "description": "RPKI group name referenced by BGP route filters"
    },
    "address": {
      "type": "string",
      "description": "Validator (RTR cache) IP address or hostname"
    },
    "port": {
      "default": 8282,
      "description": "RTR port, e.g. 8282 or 323",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "refresh_interval": {
      "description": "e.g. \"10m\"",
      "type": "string"
    },
    "expire_interval": {
      "description": "e.g. \"2h\"",
      "type": "string"
    },
    "retry_interval": {
      "description": "e.g. \"30s\"",
      "type": "string"
    },
    "vrf": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "group",
    "address",
    "port",
    "disabled"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "get_logs",
  "type": "object",
  "properties": {
    "topics": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "time_filter": {
      "type": "string"
    },
    "message_filter": {
      "type": "string"
    },
    "prefix_filter": {
      "type": "string"
    },
    "limit": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "follow": {
      "default": false,
      "type": "boolean"
    },
    "print_as": {
      "default": "value",
      "type": "string",
      "enum": [
        "value",
        "detail",
        "terse"
      ]
    }
  },
  "required": [
    "follow",
    "print_as"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_dhcp_client",
  "type": "object",
  "properties": {
    "interface": {
      "type": "string",
      "description": "Interface to run the DHCP client on, e.g. 'ether1'"
    },
    "add_default_route": {
      "default": true,
      "description": "Install the received default gateway",
      "type": "boolean"
    },
    "default_route_distance": {
      "description": "Administrative distance of the installed default route",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "use_peer_dns": {
      "default": true,
      "type": "boolean"
    },
    "use_peer_ntp": {
      "default": true,
      "type": "boolean"
    },
    "dhcp_options": {
      "description": "Comma-separated DHCP options to send, e.g. 'hostname,clientid'",
      "type": "string"
    },
    "client_id": {
      "description": "Override the DHCP client identifier sent to the server",
      "type": "string"
    },
    "host_name": {
      "description": "Host name sent to the DHCP server",
      "type": "string"
    },
    "script": {
      "description": "Script run on lease bound/released",
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    },
    "comment": {
      "type": "string"
    }
  },
  "required": [
    "interface",
    "add_default_route",
    "use_peer_dns",
    "use_peer_ntp",
    "disabled"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_ppp_secret",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Username for the secret"
    },
    "password": {
      "type": "string",
      "description": "Password for the secret"
    },
    "service": {
      "default": "any",
      "description": "Service this secret applies to",
      "type": "string",
      "enum": ["any", "l2tp", "pptp", "sstp", "ovpn", "pppoe"]
    },
    "profile": {
      "type": "string"
    },
    "local_address": {
      "type": "string"
    },
    "remote_address": {
      "type": "string"
    },
    "caller_id": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": ["name", "password", "service", "disabled"],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_ppp_secret",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Username for the secret"
    },
    "password": {
      "type": "string",
      "description": "Password for the secret"
    },
    "service": {
      "default": "any",
      "description": "Service this secret applies to",
      "type": "string",
      "enum": [
        "any",
        "l2tp",
        "pptp",
        "sstp",
        "ovpn",
        "pppoe"
      ]
    },
    "profile": {
      "type": "string"
    },
    "local_address": {
      "type": "string"
    },
    "remote_address": {
      "type": "string"
    },
    "routes": {
      "description": "Routes added while this client is connected",
      "type": "string"
    },
    "caller_id": {
      "type": "string"
    },
    "limit_bytes_in": {
      "description": "Max bytes the client may upload",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "limit_bytes_out": {
      "description": "Max bytes the client may download",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "name",
    "password",
    "service",
    "disabled"
  ],
  "additionalProperties": false
}

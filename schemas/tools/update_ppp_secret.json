{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "update_ppp_secret",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Current username of the secret to update"
    },
    "new_name": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "service": {
      "type": "string",
      "enum": [
        "any",
        "l2tp",
        "pptp",
        "sstp",
        "ovpn",
        "pppoe"
      ]
    },
    "profile": {
      "type": "string"
    },
    "local_address": {
      "type": "string"
    },
    "remote_address": {
      "type": "string"
    },
    "caller_id": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "type": "boolean"
    }
  },
  "required": [
    "name"
  ],
  "additionalProperties": false
}

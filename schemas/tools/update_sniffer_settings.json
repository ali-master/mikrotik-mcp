{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "update_sniffer_settings",
  "type": "object",
  "properties": {
    "filter_interface": {
      "type": "string"
    },
    "filter_ip_address": {
      "description": "Match IP/CIDR, e.g. '10.0.0.0/24'",
      "type": "string"
    },
    "filter_ipv6_address": {
      "description": "Match IPv6/prefix, e.g. '2001:db8::/64'",
      "type": "string"
    },
    "filter_mac_address": {
      "description": "Match MAC address",
      "type": "string"
    },
    "filter_port": {
      "type": "string"
    },
    "filter_mac_protocol": {
      "type": "string"
    },
    "filter_direction": {
      "description": "Capture direction: any, rx, or tx",
      "type": "string",
      "enum": ["any", "rx", "tx"]
    },
    "filter_operator_between_entries": {
      "description": "How filter entries combine: and / or",
      "type": "string",
      "enum": ["and", "or"]
    },
    "filter_stream": {
      "description": "Capture only TZSP-streamed packets",
      "type": "boolean"
    },
    "streaming_enabled": {
      "type": "boolean"
    },
    "streaming_server": {
      "description": "TZSP target, e.g. '192.168.88.2'",
      "type": "string"
    },
    "memory_limit": {
      "description": "Buffer size, e.g. '10M'",
      "type": "string"
    },
    "memory_scroll": {
      "description": "Overwrite oldest packets when buffer is full",
      "type": "boolean"
    },
    "file_name": {
      "description": "Capture file name (.pcap)",
      "type": "string"
    },
    "file_limit": {
      "description": "Max capture file size in KiB",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "only_headers": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_pptp_client",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name for the new PPTP client interface"
    },
    "connect_to": {
      "type": "string",
      "description": "Remote PPTP server address"
    },
    "user": {
      "type": "string",
      "description": "Username for authentication"
    },
    "password": {
      "type": "string",
      "description": "Password for authentication"
    },
    "profile": {
      "type": "string"
    },
    "add_default_route": {
      "type": "boolean"
    },
    "default_route_distance": {
      "description": "Distance for the default route installed via this tunnel",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "allow": {
      "description": "Allowed auth protocols, comma-separated, e.g. 'mschap2,mschap1'",
      "type": "string"
    },
    "dial_on_demand": {
      "description": "Connect only when outbound traffic is generated",
      "type": "boolean"
    },
    "max_mtu": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "max_mru": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "mrru": {
      "description": "Max packet size for MP reassembly, or 'disabled'",
      "type": "string"
    },
    "keepalive_timeout": {
      "description": "Keepalive timeout in seconds, or 'disabled'",
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "name",
    "connect_to",
    "user",
    "password",
    "disabled"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_ipip_tunnel",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name for the new IPIP tunnel interface, e.g. 'ipip-to-hq'"
    },
    "remote_address": {
      "type": "string",
      "description": "Remote endpoint IP address"
    },
    "local_address": {
      "description": "Local endpoint IP address",
      "type": "string"
    },
    "keepalive": {
      "description": "Keepalive interval/retries, e.g. '10s,3'",
      "type": "string"
    },
    "dont_fragment": {
      "description": "Don't-fragment behavior",
      "type": "string",
      "enum": [
        "inherit",
        "no"
      ]
    },
    "clamp_tcp_mss": {
      "description": "Clamp TCP MSS to the tunnel MTU",
      "type": "boolean"
    },
    "allow_fast_path": {
      "description": "Allow FastPath processing for this tunnel",
      "type": "boolean"
    },
    "ipsec_secret": {
      "description": "Pre-shared key to auto-create an IPsec policy securing the tunnel",
      "type": "string"
    },
    "dscp": {
      "description": "DSCP for encapsulated packets: 'inherit' or 0-63",
      "type": "string"
    },
    "mtu": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "name",
    "remote_address",
    "disabled"
  ],
  "additionalProperties": false
}

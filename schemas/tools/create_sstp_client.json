{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_sstp_client",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name for the new SSTP client interface"
    },
    "connect_to": {
      "type": "string",
      "description": "Remote SSTP server address (IP or DNS name; host:port also accepted)"
    },
    "port": {
      "description": "TCP port (default 443 if omitted)",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "user": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "certificate": {
      "description": "Client TLS certificate name",
      "type": "string"
    },
    "verify_server_certificate": {
      "type": "boolean"
    },
    "add_default_route": {
      "type": "boolean"
    },
    "http_proxy": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": ["name", "connect_to", "user", "password", "disabled"],
  "additionalProperties": false
}

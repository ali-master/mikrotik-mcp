{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_sstp_client",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name for the new SSTP client interface"
    },
    "connect_to": {
      "type": "string",
      "description": "Remote SSTP server address (IP or DNS name; host:port also accepted)"
    },
    "port": {
      "description": "TCP port (default 443 if omitted)",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "user": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "certificate": {
      "description": "Client TLS certificate name",
      "type": "string"
    },
    "verify_server_certificate": {
      "type": "boolean"
    },
    "authentication": {
      "description": "Comma-separated, e.g. 'mschap2,mschap1'",
      "type": "string"
    },
    "tls_version": {
      "type": "string",
      "enum": [
        "any",
        "only-1.2"
      ]
    },
    "pfs": {
      "description": "Enable Perfect Forward Secrecy",
      "type": "boolean"
    },
    "add_default_route": {
      "type": "boolean"
    },
    "default_route_distance": {
      "description": "Distance of the auto-added default route",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "dial_on_demand": {
      "description": "Connect only when traffic is sent over the tunnel",
      "type": "boolean"
    },
    "max_mtu": {
      "description": "Maximum transmission unit",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "max_mru": {
      "description": "Maximum receive unit",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "mrru": {
      "description": "Max receive reconstructed unit for MP",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "keepalive_timeout": {
      "description": "Seconds before an idle connection is considered down",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "http_proxy": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "name",
    "connect_to",
    "user",
    "password",
    "disabled"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "set_sstp_server",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean"
    },
    "default_profile": {
      "type": "string"
    },
    "authentication": {
      "description": "Comma-separated, e.g. 'mschap2,mschap1'",
      "type": "string"
    },
    "certificate": {
      "description": "TLS certificate name",
      "type": "string"
    },
    "port": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "tls_version": {
      "type": "string",
      "enum": ["any", "only-1.2"]
    },
    "verify_client_certificate": {
      "type": "boolean"
    },
    "pfs": {
      "description": "Enable Perfect Forward Secrecy",
      "type": "boolean"
    },
    "force_aes": {
      "description": "Require clients to use AES ciphers",
      "type": "boolean"
    },
    "max_mtu": {
      "description": "Maximum transmission unit",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "max_mru": {
      "description": "Maximum receive unit",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "mrru": {
      "description": "Max receive reconstructed unit for MP",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "keepalive_timeout": {
      "description": "Seconds before an idle connection is considered down",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    }
  },
  "additionalProperties": false
}

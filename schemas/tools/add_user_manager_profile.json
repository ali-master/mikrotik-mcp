{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_user_manager_profile",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Profile name"
    },
    "name_for_users": {
      "description": "Display name shown to users",
      "type": "string"
    },
    "validity": {
      "description": "Validity period, e.g. '30d'",
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "starts_when": {
      "type": "string",
      "enum": ["assigned", "first-auth"]
    },
    "override_shared_users": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    }
  },
  "required": ["name"],
  "additionalProperties": false
}

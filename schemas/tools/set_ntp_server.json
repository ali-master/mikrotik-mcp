{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "set_ntp_server",
  "type": "object",
  "properties": {
    "enabled": {
      "description": "Enable or disable the NTP server",
      "type": "boolean"
    },
    "broadcast": {
      "type": "boolean"
    },
    "multicast": {
      "type": "boolean"
    },
    "manycast": {
      "type": "boolean"
    },
    "broadcast_address": {
      "description": "Broadcast address for NTP broadcasts",
      "type": "string"
    },
    "use_local_clock": {
      "description": "Serve time from the device's local clock as reference",
      "type": "boolean"
    },
    "local_clock_stratum": {
      "description": "Stratum advertised when using the local clock (1-15)",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    }
  },
  "additionalProperties": false
}

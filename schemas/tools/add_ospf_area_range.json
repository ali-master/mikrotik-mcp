{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_ospf_area_range",
  "type": "object",
  "properties": {
    "area": {
      "type": "string",
      "description": "OSPF area name"
    },
    "prefix": {
      "type": "string",
      "description": "Aggregate prefix, e.g. \"10.10.0.0/16\""
    },
    "advertise": {
      "default": true,
      "description": "Advertise the summary (false suppresses it)",
      "type": "boolean"
    },
    "cost": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "type": "boolean"
    }
  },
  "required": ["area", "prefix", "advertise"],
  "additionalProperties": false
}

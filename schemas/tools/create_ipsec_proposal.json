{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_ipsec_proposal",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name for the new IPsec proposal"
    },
    "auth_algorithms": {
      "default": "sha256",
      "description": "Authentication algorithms, e.g. 'sha256'",
      "type": "string"
    },
    "enc_algorithms": {
      "default": "aes-256-cbc",
      "description": "Encryption algorithms, e.g. 'aes-256-cbc'",
      "type": "string"
    },
    "pfs_group": {
      "default": "modp2048",
      "description": "PFS group, e.g. 'modp2048'",
      "type": "string"
    },
    "lifetime": {
      "description": "Phase-2 lifetime, e.g. '30m'",
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": ["name", "auth_algorithms", "enc_algorithms", "pfs_group", "disabled"],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_vlan_interface",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name for the new VLAN interface, e.g. 'vlan100'"
    },
    "vlan_id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4094,
      "description": "802.1Q VLAN ID (1-4094)"
    },
    "interface": {
      "type": "string",
      "description": "Parent interface, e.g. 'ether1' or 'bridge'"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    },
    "mtu": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "use_service_tag": {
      "default": false,
      "description": "Use 802.1ad service tag (QinQ)",
      "type": "boolean"
    },
    "arp": {
      "default": "enabled",
      "type": "string",
      "enum": ["enabled", "disabled", "proxy-arp", "reply-only"]
    },
    "arp_timeout": {
      "type": "string"
    }
  },
  "required": ["name", "vlan_id", "interface", "disabled", "use_service_tag", "arp"],
  "additionalProperties": false
}

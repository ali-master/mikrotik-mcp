{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_rip_instance",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique instance name"
    },
    "router_id": {
      "description": "IPv4 address, 'main', or a /routing id name",
      "type": "string"
    },
    "vrf": {
      "type": "string"
    },
    "routing_table": {
      "description": "Routing table to install routes into",
      "type": "string"
    },
    "redistribute": {
      "description": "Comma list, e.g. \"connected,static\"",
      "type": "string"
    },
    "in_filter_chain": {
      "type": "string"
    },
    "out_filter_chain": {
      "type": "string"
    },
    "originate_default": {
      "description": "never, if-installed, or always",
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": ["name", "disabled"],
  "additionalProperties": false
}

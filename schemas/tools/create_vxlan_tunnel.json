{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_vxlan_tunnel",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name for the new VXLAN interface, e.g. 'vxlan1'"
    },
    "vni": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991,
      "description": "VXLAN Network Identifier (VNI)"
    },
    "port": {
      "default": 8472,
      "description": "UDP port (default 8472)",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "local_address": {
      "description": "Local source IP address",
      "type": "string"
    },
    "interface": {
      "description": "Source interface",
      "type": "string"
    },
    "group": {
      "description": "Multicast group address for broadcast/unknown-unicast flooding",
      "type": "string"
    },
    "vteps_ip_version": {
      "description": "IP version used for VTEP addressing",
      "type": "string",
      "enum": ["ipv4", "ipv6"]
    },
    "mac_address": {
      "description": "MAC address of the VXLAN interface",
      "type": "string"
    },
    "arp": {
      "description": "Address Resolution Protocol mode for the interface",
      "type": "string",
      "enum": ["disabled", "enabled", "local-proxy-arp", "proxy-arp", "reply-only"]
    },
    "arp_timeout": {
      "description": "ARP entry timeout, e.g. '30s' or 'auto'",
      "type": "string"
    },
    "max_fdb_size": {
      "description": "Maximum forwarding database (FDB) size",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "allow_fast_path": {
      "description": "Allow FastPath processing for this interface",
      "type": "boolean"
    },
    "mtu": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": ["name", "vni", "port", "disabled"],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_pimsm_interface_template",
  "type": "object",
  "properties": {
    "instance": {
      "type": "string",
      "description": "PIM-SM instance name"
    },
    "interfaces": {
      "type": "string",
      "description": "Interface or interface-list name"
    },
    "priority": {
      "description": "DR election priority",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "hello_period": {
      "description": "Hello interval, e.g. \"30s\"",
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "disabled": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "instance",
    "interfaces",
    "disabled"
  ],
  "additionalProperties": false
}

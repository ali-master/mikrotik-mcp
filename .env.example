# ── MikroTik connection ──────────────────────────────────────────────────────
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USERNAME=admin
MIKROTIK_PASSWORD=
MIKROTIK_PORT=22
# Key-based auth (takes precedence over the password if set):
# MIKROTIK_KEY_FILENAME=/home/you/.ssh/id_ed25519
# MIKROTIK_PRIVATE_KEY=            # inline PEM, alternative to a file path
# MIKROTIK_KEY_PASSPHRASE=         # only if the private key is encrypted
# MIKROTIK_TIMEOUT_MS=10000

# ── Multiple devices (optional) ──────────────────────────────────────────────
# Manage several routers; the AI targets one per call via a `device` argument.
# Point at a JSON file …
# MIKROTIK_CONFIG_FILE=./devices.json
# … or inline the map (the legacy MIKROTIK_* above still adds a "default" device):
# MIKROTIK_DEVICES={"defaultDevice":"site-a","devices":{"site-a":{"host":"203.0.113.10","keyFilename":"/keys/a"},"site-b":{"host":"198.51.100.20","password":"x"}}}

# ── S3 backup storage (optional) ─────────────────────────────────────────────
# Ship device backups/exports to S3-compatible storage. Leave unset to disable.
# Credentials follow Bun's native lookup: S3_* first, then AWS_* as a fallback.
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=my-mikrotik-backups
# S3_REGION=us-east-1
# Custom endpoint for R2 / MinIO / Spaces (omit for AWS S3):
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_SESSION_TOKEN=
# Backups are organised per device as "<prefix>/<device>/<file>":
# MIKROTIK_S3_PREFIX=mikrotik/
# Presigned-URL lifetime (seconds) for the device's /tool fetch transfer:
# MIKROTIK_S3_PRESIGN_EXPIRES_IN=3600

# ── MCP transport ────────────────────────────────────────────────────────────
# stdio (default) | streamable-http | sse
MIKROTIK_MCP__TRANSPORT=stdio
# HTTP transports only:
MIKROTIK_MCP__HOST=0.0.0.0
MIKROTIK_MCP__PORT=8000
# Comma-separated Host/Origin allow-lists for DNS-rebinding protection behind a proxy.
# Set ALLOWED_HOSTS to your domain (e.g. mcp.example.com); "*" disables the check.
# MIKROTIK_MCP__ALLOWED_HOSTS=
# MIKROTIK_MCP__ALLOWED_ORIGINS=
# CORS allow-list for /mcp (needed by the ChatGPT Apps connector). Empty = the
# built-in ChatGPT/Claude origins; comma-separated list to add more; "*" = any.
# MIKROTIK_MCP__CORS_ORIGINS=

# ── Public exposure safety ───────────────────────────────────────────────────
# Read-only mode: register only inspection tools (no writes). Strongly
# recommended whenever the server is reachable publicly (e.g. a ChatGPT Apps
# connector) before authentication is in place.
# MIKROTIK_READ_ONLY=true

# ── Logging (to stderr) ──────────────────────────────────────────────────────
# debug | info | warn | error
MIKROTIK_LOG_LEVEL=info

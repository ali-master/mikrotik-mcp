# ── MikroTik connection ──────────────────────────────────────────────────────
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USERNAME=admin
MIKROTIK_PASSWORD=
MIKROTIK_PORT=22
# Key-based auth (takes precedence over the password if set):
# MIKROTIK_KEY_FILENAME=/home/you/.ssh/id_ed25519
# MIKROTIK_PRIVATE_KEY=            # inline PEM, alternative to a file path
# MIKROTIK_KEY_PASSPHRASE=         # only if the private key is encrypted
# MIKROTIK_TIMEOUT_MS=10000

# ── Multiple devices (optional) ──────────────────────────────────────────────
# Manage several routers; the AI targets one per call via a `device` argument.
# Point at a JSON file …
# MIKROTIK_CONFIG_FILE=./devices.json
# … or inline the map (the legacy MIKROTIK_* above still adds a "default" device):
# MIKROTIK_DEVICES={"defaultDevice":"site-a","devices":{"site-a":{"host":"203.0.113.10","keyFilename":"/keys/a"},"site-b":{"host":"198.51.100.20","password":"x"}}}

# ── MCP transport ────────────────────────────────────────────────────────────
# stdio (default) | streamable-http | sse
MIKROTIK_MCP__TRANSPORT=stdio
# HTTP transports only:
MIKROTIK_MCP__HOST=0.0.0.0
MIKROTIK_MCP__PORT=8000
# Comma-separated Host/Origin allow-lists for DNS-rebinding protection behind a proxy.
# Set ALLOWED_HOSTS to your domain (e.g. mcp.example.com); "*" disables the check.
# MIKROTIK_MCP__ALLOWED_HOSTS=
# MIKROTIK_MCP__ALLOWED_ORIGINS=

# ── Logging (to stderr) ──────────────────────────────────────────────────────
# debug | info | warn | error
MIKROTIK_LOG_LEVEL=info
